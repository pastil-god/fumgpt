NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BRAND_NAME=FumGPT
NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com
NEXT_PUBLIC_SUPPORT_PHONE=0900 000 0000
NEXT_PUBLIC_SUPPORT_ADDRESS=پاسخ‌گویی آنلاین و تحویل دیجیتال در سراسر ایران
NEXT_PUBLIC_SUPPORT_TELEGRAM=https://t.me/example
NEXT_PUBLIC_SUPPORT_WHATSAPP=https://wa.me/989000000000
NEXT_PUBLIC_INSTAGRAM=https://instagram.com/example
NEXT_PUBLIC_CMS_DASHBOARD_URL=https://app.contentful.com/spaces/your-space-id

# Neon pooled URL (host contains "-pooler") for app runtime and Prisma Client
DATABASE_URL=postgresql://DB_USER:DB_PASSWORD@EP-XXXX-POOLER.REGION.aws.neon.tech/DB_NAME?sslmode=require&pgbouncer=true&connect_timeout=15

# Neon direct URL (host does NOT contain "-pooler") for Prisma migrations
DIRECT_URL=postgresql://DB_USER:DB_PASSWORD@EP-XXXX.REGION.aws.neon.tech/DB_NAME?sslmode=require&connect_timeout=15

AUTH_EMAIL_TRANSPORT=mock
AUTH_EMAIL_FROM=auth@example.com
RESEND_API_KEY=
AUTH_SMS_TRANSPORT=mock

CONTENTFUL_SPACE_ID=replace_with_contentful_space_id
CONTENTFUL_DELIVERY_TOKEN=replace_with_contentful_delivery_token
CONTENTFUL_ENVIRONMENT=master

# Internal StoreProduct overrides are ignored unless explicitly enabled.
# Safe default when omitted: false, so Contentful -> local fallback remains unchanged.
PRODUCTS_INTERNAL_ENABLED=true

CHECKOUT_PAYMENT_PROVIDER=manual
ANALYTICS_ADAPTER=disabled
STORE_LOG_FILE_PATH=
MONITORING_ADAPTER=disabled

NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_ENABLE_REAL_COMMERCE=false

PAYMENT_PROVIDER=zibal
PAYMENT_API_KEY=replace_me_later

SMS_PROVIDER=kavenegar
SMS_API_KEY=replace_me_later
SMS_TEMPLATE_LOGIN_OTP=replace_me_later

# Optional: Cloudinary image upload for super_admin media fields
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=fumgpt/admin
